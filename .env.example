# ============================================================
# Dafne Bot — Coral Mujeres
# Copia este archivo como .env y llena los valores reales
# NUNCA subas el archivo .env a Git
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-TU_CLAVE_AQUI
OPENAI_MODEL=gpt-4o

# Whapi (WhatsApp)
WHAPI_URL=https://gate.whapi.cloud/
WHAPI_TOKEN=TU_NUEVO_TOKEN_WHAPI

# Discord
DISCORD_BOT_TOKEN=TU_NUEVO_TOKEN_DISCORD
DISCORD_ALERTS_CHANNEL_ID=ID_DEL_CANAL_alertas-whatsapp
DISCORD_LEADS_CHANNEL_ID=ID_DEL_CANAL_leads-terminados

# Seguridad del webhook (opcional pero recomendado)
# Genera un token aleatorio: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# Base de datos SQLite
DB_PATH=dafne_bot.db
